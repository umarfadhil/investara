{
  "name": "investara",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "node scripts/dev-web.mjs",
    "web:dev": "npm --workspace apps/web run dev",
    "web:build": "npm --workspace apps/web run build",
    "web:lint": "npm --workspace apps/web run lint",
    "data:sync:bkpm": "node scripts/sync-bkpm-opportunities.mjs",
    "api:dev": "cd apps/api && .\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --port 8000",
    "api:test": "cd apps/api && .\\.venv\\Scripts\\python.exe -m pytest",
    "api:lint": "cd apps/api && .\\.venv\\Scripts\\python.exe -m ruff check app tests",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "next": "16.2.4",
    "playwright": "^1.59.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.4",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
